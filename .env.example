# What About — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# Perplexity Sonar Pro (REQUIS — collecteur principal)
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# YouTube Data API v3 (optionnel — fallback RSS sans cle)
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# GitHub (optionnel — meilleur rate limit: 30 req/min au lieu de 10)
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Product Hunt (optionnel — fallback RSS sans token)
# https://api.producthunt.com/v2/oauth/applications -> Developer Token
PRODUCTHUNT_TOKEN=
